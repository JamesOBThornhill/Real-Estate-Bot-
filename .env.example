# ─── Agency ───────────────────────────────────────────────────────────────────
AGENCY_NAME=Prestige Property Group

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+441234567890       # Your Twilio inbound number (calls come in here)
TWILIO_WHATSAPP_NUMBER=+14155238886     # Twilio WhatsApp sandbox number

# ─── Deepgram (Speech-to-Text) ────────────────────────────────────────────────
# Get from: https://console.deepgram.com — free tier: 45hrs/month
DEEPGRAM_API_KEY=your_deepgram_api_key

# ─── Anthropic (AI Brain) ─────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── ElevenLabs (Natural Voice TTS) ──────────────────────────────────────────
# Get from: https://elevenlabs.io — free tier: 10k chars/month
# Recommended voices: Rachel (21m00Tcm4TlvDq8ikWAM), Bella (EXAVITQu4vr4xnSDxMaL)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── SendGrid (Email) ─────────────────────────────────────────────────────────
# Get from: https://sendgrid.com — free tier: 100 emails/day
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@youragency.com

# ─── Rep Contact Details ──────────────────────────────────────────────────────
REP_EMAIL=agent@youragency.com
REP_PHONE=+447700900000                 # Mobile for SMS alerts
REP_WHATSAPP=+447700900000              # WhatsApp number (usually same as mobile)

# ─── Slack ────────────────────────────────────────────────────────────────────
# Create incoming webhook at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/xxxxxxxxxx
